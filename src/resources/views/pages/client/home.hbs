                                        <circle cx="12" cy="12" r="1"></circle>
                                        <circle cx="12" cy="5" r="1"></circle>
                                        <circle cx="12" cy="19" r="1"></circle>
                                    </svg>
                                </button>
                        
                            </div>
                            <p style="color: deeppink;font-size: 16px;top: 46px;position: relative;font-family: emoji;">{{this.views}} lượt nghe</p>
                            </div>
                            <h3 style="max-width: 160px;overflow: hidden;text-overflow: ellipsis">{{this.title}}</h3>
                            <p style="max-width: 160px;overflow: hidden;text-overflow: ellipsis">{{this.artist}}</p>
                        </div>
                        {{/each}}
                    </div>
                </section>

                <!-- Hàng bài hát 3 -->
                <section class="song-row">
                    <h2 class="song-row-title">Gợi ý cho bạn</h2>
                    <div class="song-row-scroll">
