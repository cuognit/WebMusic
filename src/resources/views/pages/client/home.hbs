<link rel="stylesheet" href="/css/login_register.css">
<link rel="stylesheet" href="/css/app.css">
<!-- ===== Khu vực chính (Header + Content + Player) ===== -->
     
            {{!-- // ===== Form Đăng Nhập & Đăng Ký ===== --}}
            <div id="auth-layout">
            <div class="auth-container" id="container">

        <!-- Form Đăng Ký (Bên phải) -->
        <div class="auth-form-container auth-sign-up-container">
            <form action="#" id="register-form">
                <div class="auth-title">Tạo tài khoản</div>
                <p class="auth-subtitle">sử dụng email của bạn để đăng ký</p>
                <input type="text" placeholder="Tên" class="auth-form-input" name="name" id="name"  required/>
                <input type="email" placeholder="Email" class="auth-form-input" name="email" id="email" required/>
                <input type="password" placeholder="Mật khẩu" class="auth-form-input" name="password" id="password" required/>
                <button class="auth-form-button" id="registerBtn">Đăng Ký</button>
            </form>
        </div>

        <!-- Form Đăng Nhập (Bên trái) -->
        <div class="auth-form-container auth-sign-in-container">
            <form action="#" id="login-form">
                <div class="auth-title">Đăng Nhập</div>
                <p class="auth-subtitle">sử dụng tài khoản của bạn</p>
                <input type="email" placeholder="Email" class="auth-form-input" name="email" id="email2" required/>
                <input type="password" placeholder="Mật khẩu" class="auth-form-input" name="password" id="password2" required/>
                <a href="#" class="auth-forgot-password">Quên mật khẩu?</a>
                <button class="auth-form-button" id="loginBtn">Đăng Nhập</button>
            </form>
        </div>

        <!-- Container Lớp Phủ (Overlay) -->
        <div class="auth-overlay-container">
            <div class="auth-overlay">
                
                <!-- Panel bên trái (hiện khi form Đăng ký active) -->
                <div class="auth-overlay-panel auth-overlay-left">
                    <div class="auth-title">Chào mừng trở lại!</div>
                    <p>
                        Đã có tài khoản? Đăng nhập ngay để tiếp tục nhé.
                    </p>
                    <button class="auth-ghost-button" id="signIn">Đăng Nhập</button>
                </div>

                <!-- Panel bên phải (hiện khi form Đăng nhập active - Mặc định) -->
                <div class="auth-overlay-panel auth-overlay-right">
                    <div class="auth-title">Xin chào, bạn!</div>
                    <p>
                        Bạn chưa có tài khoản? Hãy đăng ký để bắt đầu hành trình mới.
                    </p>
                    <button class="auth-ghost-button" id="signUp">Đăng Ký</button>
                </div>
                
            </div>
        </div>

        </div>
        </div>
        <div id="main-container">

           <!-- ===== Sidebar ===== -->
        <!-- SỬA: Đã xóa hết class Tailwind, chỉ giữ ID và class tùy chỉnh -->
        <nav id="sidebar" class="sidebar-expanded">

            <div class="sidebar-nav-list">
                <!-- Trang chủ -->
                <a href="/" class="nav-item active" title="Trang chủ">
                    <!-- SỬA: Thay <i> bằng <svg> -->
                    <svg class="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                        <polyline points="9 22 9 12 15 12 15 22"></polyline>
                    </svg>
                    <span class="nav-text">Trang chủ</span>
                </a>

                <!-- Thư viện -->
                <a href="/user/library" class="nav-item" title="Thư viện">
                    <!-- SỬA: Thay <i> bằng <svg> -->
                    <svg class="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="m16 6 4 14"/>
                        <path d="M12 6v14"/>
                        <path d="M8 8v12"/>
                        <path d="M4 4v16"/>
                    </svg>
                    <span class="nav-text">Thư viện</span>
                </a>

                <!-- Thêm DS Phát -->
                <a href="#" class="nav-item" title="Thêm danh sách phát">
                    <!-- SỬA: Thay <i> bằng <svg> -->
                    <svg class="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="12" y1="5" x2="12" y2="19"></line>
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                    </svg>
                    <span class="nav-text">Thêm danh sách phát</span>
                </a>

                <hr>

                <!-- Yêu thích -->
                <a href="user/favorites" class="nav-item" title="Yêu thích">
                    <!-- SỬA: Thay <i> bằng <svg> -->
                    <svg class="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                    </svg>
                    <span class="nav-text">Yêu thích</span>
                </a>

                <!-- Đã nghe -->
                <a href="/user/history" class="nav-item" title="Đã nghe">
                    <!-- SỬA: Thay <i> bằng <svg> -->
                    <svg class="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 12A9 9 0 1 0 12 3v9"></path>
                        <path d="M12 8v4l4 2"></path>
                    </svg>
                    <span class="nav-text">Đã nghe</span>
                </a>
            </div>
        </nav>
        <!-- ===== Kết thúc Sidebar ===== -->

            <!-- ===== Content (Scrollable) ===== -->
            <main id="content">
                
                <!-- Hàng bài hát 1 -->
                <section class="song-row">
                    <h2 class="song-row-title">Mới phát hành</h2>
                    <div class="song-row-scroll">
                        {{#each songs }}
                        
                        <div class="song-card" data-id="{{this._id}}" data-title="{{this.title}}" data-artist="{{this.artist}}" data-img="{{this.image}}" data-youtube-id="{{this.fileUrl}}" data-views="{{this.views}}" data-duration="{{this.duration}}">
                            <img src="{{this.image}}" class="song-card-image">
                            <div class="song-card-overlay">
                            <div class="song-card-overlay">
                                <button class="song-card-button" title="Yêu thích" >
                                     {{#if isFavorite}}
                                    <i title="Yêu thích" data-id="{{this._id}}" class="fa-solid fa-heart like_icon" style="font-size: 16px;color: red;cursor: pointer;"></i>
                                    {{else}}
                                     <i title="Yêu thích" data-id="{{this._id}}" class="fa-regular fa-heart like_icon" style="font-size: 16px;color: red;cursor: pointer;"></i>
                                    {{/if}}
                                </button>
                                <button class="song-card-button" title="Tùy chọn">
                                    <!-- SỬA: Thay <i> bằng <svg> -->
                                    <svg class="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <circle cx="12" cy="12" r="1"></circle>
                                        <circle cx="12" cy="5" r="1"></circle>
                                        <circle cx="12" cy="19" r="1"></circle>
                                    </svg>
                                </button>
                        
                            </div>
                            <p style="color: deeppink;font-size: 16px;top: 46px;position: relative;font-family: emoji;">{{this.views}} lượt nghe</p>
                            </div>
                            <h3 style="max-width: 160px;overflow: hidden;text-overflow: ellipsis">{{this.title}}</h3>
                            <p style="max-width: 160px;overflow: hidden;text-overflow: ellipsis">{{this.artist}}</p>
                        </div>
                       
                        {{/each}}
                    </div>
                </section>

                <!-- Hàng bài hát 2 -->
