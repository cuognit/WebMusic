                    </div>
                </section>

            </main>
            <!-- ===== Kết thúc Content ===== -->

            <!-- ===== Giao diện phát nhạc (Player View) - Ẩn ban đầu ===== -->
            <div id="player-view">
                <div class="player-view-content">
                    
                    <div class="player-video-container">
                        <div class="player-video-wrapper">

                            <div id="full-youtube-player">

                            </div>
                        </div>
                    </div>

                    <div class="player-queue-container">
                        <div class="player-queue-tabs">
                            <button>Tiếp theo</button>
                        </div>
                        {{#each songs}}
                       
                        <div class="player-queue-list">
                            <div class="player-queue-item" data-fileUrl="{{this.fileUrl}}">
                                <img src="{{this.image}}" class="queue-item-image">
                                <div class="queue-item-info" style="display: flex;flex:1;justify-content: space-between;align-items: center;">
                                    <div><p class="queue-item-title">{{this.title}}</p>
                                    <p class="queue-item-artist">{{this.artist}}</p>
                                    </div>
                                    <div class="song-card-overlay2 ">
                                    <button class="song-card-button" title="Yêu thích">
                                        {{#if isFavorite}}
                                    <i title="Yêu thích" data-id="{{this._id}}"  class="fa-solid fa-heart like_icon" style="font-size: 16px;color: red;cursor: pointer;"></i>
                                    {{else}}
                                     <i title="Yêu thích" data-id="{{this._id}}"  class="fa-regular fa-heart like_icon" style="font-size: 16px;color: red;cursor: pointer;"></i>
                                    {{/if}}
                                    </button>
                                    <button class="song-card-button" title="Tùy chọn">
                                        <svg class="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="1"></circle><circle cx="12" cy="5" r="1"></circle><circle cx="12" cy="19" r="1"></circle></svg>
                                    </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        {{/each}}
                    </div>
                </div>
            </div>
            <!-- ===== Kết thúc Giao diện phát nhạc ===== -->


            <!-- ===== Thanh điều khiển (Control Bar) - (Trước là Mini Player) ===== -->
            <div id="music-player-mini">
                
                <div class="mini-player-grid">
                    
                    <div class="player-controls-left">
                        <button id="mini-skip-back-btn" class="control-button" title="Quay lại">
                            <!-- SỬA: Thay <i> bằng <svg> -->
                            <svg class="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polygon points="19 20 9 12 19 4 19 20"></polygon>
                                <line x1="5" y1="19" x2="5" y2="5"></line>
                            </svg>
                        </button>
                        <button id="mini-play-btn" class="play-button" title="Phát/Tạm dừng">
                            <!-- SỬA: Thay <i> bằng <svg> -->
                            <svg id="mini-play-icon-play" class="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polygon points="5 3 19 12 5 21 5 3"></polygon>
                            </svg>
                            <svg id="mini-play-icon-pause" class="icon hidden" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="6" y="4" width="4" height="16"></rect>
                                <rect x="14" y="4" width="4" height="16"></rect>
                            </svg>
                        </button>
                        <button id="mini-skip-fwd-btn" class="control-button" title="Tiếp theo">
                            <!-- SỬA: Thay <i> bằng <svg> -->
                            <svg class="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polygon points="5 4 15 12 5 20 5 4"></polygon>
                                <line x1="19" y1="5" x2="19" y2="19"></line>
                            </svg>
                        </button>
                        
                        <button id="mini-like-btn" class="like-button" title="Thích">
                           
                                {{#if user}}
                                    <p>{{this._id}}</p>
                                    <i title="Yêu thích"  class="fa-solid fa-heart like_icon" style="font-size: 16px;color: red;cursor: pointer;"></i>
                                {{else}}
                                     <i title="Yêu thích"  class="fa-regular fa-heart like_icon" style="font-size: 16px;color: red;cursor: pointer;"></i>
                                {{/if}}
                           

                          
                        </button>
                    </div>

                    <div class="player-controls-center">
                        <span id="current-time-text" class="time-text right">0:00</span>
                        <input id="main-progress-bar" type="range" min="0" max="100" value="0">
                        <span id="duration-time-text" class="time-text left">0:00</span>
                    </div>

                    <div class="player-controls-right">
                        
                        <div class="volume-container">
                            <button id="mini-volume-btn" class="control-button" title="Âm lượng">
                                <!-- SỬA: Thay <i> bằng <svg> -->
                                <svg id="volume-icon" class="icon icon-sm" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
                                    <path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"></path>
                                    <!-- Volume 1 path: <path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path> -->
                                    <!-- Volume X path: <line x1="23" y1="9" x2="17" y2="15"></line><line x1="17" y1="9" x2="23" y2="15"></line> -->
                                </svg>
                            </button>
                            <div class="volume-popup">
                                <input id="volume-slider" type="range" min="0" max="100" value="100">
                            </div>
                        </div>

                        <button id="mini-repeat-btn" class="control-button" title="Lặp lại">
                            <!-- SỬA: Thay <i> bằng <svg> -->
                            <svg class="icon icon-sm" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="17 1 21 5 17 9"></polyline>
                                <path d="M3 11V9a4 4 0 0 1 4-4h14"></path>
                                <polyline points="7 23 3 19 7 15"></polyline>
                                <path d="M21 13v2a4 4 0 0 1-4 4H3"></path>
                            </svg>
                        </button>
                        <button id="mini-shuffle-btn" class="control-button" title="Phát ngẫu nhiên">
                            <!-- SỬA: Thay <i> bằng <svg> -->
                            <svg class="icon icon-sm" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="16 3 21 3 21 8"></polyline>
                                <line x1="4" y1="20" x2="21" y2="3"></line>
                                <polyline points="16 21 21 21 21 16"></polyline>
                                <line x1="15" y1="15" x2="21" y2="21"></line>
                                <line x1="4" y1="4" x2="9" y2="9"></line>
                            </svg>
                        </button>
                        <button id="mini-more-btn" class="control-button" title="Tùy chọn khác">
                            <!-- SỬA: Thay <i> bằng <svg> -->
                            <svg class="icon icon-sm" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="1"></circle>
                                <circle cx="19" cy="12" r="1"></circle>
                                <circle cx="5" cy="12" r="1"></circle>
                            </svg>
                        </button>

                        <div class="divider"></div>

                        <div class="mini-song-info">
                            <img id="mini-img" src="https://placehold.co/50x50/fecdd3/db2777?text=NM">
                            <div>
                                <h4 id="mini-title">Chưa phát nhạc</h4>
                                <p id="mini-artist">Chọn một bài hát</p>
                            </div>
                        </div>
                        
