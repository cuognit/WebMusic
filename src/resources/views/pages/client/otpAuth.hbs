
<h1>OTP</h1>

    
      <div class="alert alert-warning alert-dismissible fade show" role="alert">
  <strong>Cảnh báo!</strong> Please check your email for OTP verification.
  <button type="button" class="close" data-dismiss="alert" aria-label="Close">
    
  </button>  
</div>

{{#if errorMsg}}
      <div class="alert alert-warning alert-dismissible fade show" role="alert">
  <strong>Cảnh báo!</strong> {{errorMsg}}
  <button type="button" class="close" data-dismiss="alert" aria-label="Close">
    <span aria-hidden="true">&times;</span>
  </button>  
</div>
{{/if}}
{{#if errorMsg2}}
      <div class="alert alert-warning alert-dismissible fade show" role="alert">
  <strong>Cảnh báo!</strong> {{errorMsg2}}
  <button type="button" class="close" data-dismiss="alert" aria-label="Close">
    <span aria-hidden="true">&times;</span>
  </button>  
</div>
{{/if}}
<form method="POST" action="" >
  <div class="form-group">
    <label for="exampleInputEmail1">Xác thực OTP</label>
    <input type="otp" class="form-control" id="otp" name="otp" aria-describedby="emailHelp">
    <small id="otp" class="form-text text-muted"></small>
  </div>
  
  <button type="submit" class="btn btn-primary">Submit</button>
</form>